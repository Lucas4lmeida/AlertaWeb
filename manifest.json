{
  "manifest_version": 3,
  "name": "AlertaWeb — Detector de Golpes",
  "version": "1.1.0",
  "description": "Analisa páginas web em tempo real para detectar golpes, fraudes e phishing usando IA e heurísticas avançadas.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://safebrowsing.googleapis.com/*",
    "https://www.virustotal.com/*",
    "https://api.ip2whois.com/*",
    "https://www.google.com/s2/favicons*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://mail.yahoo.com/*"
      ],
      "js": ["email-scanner.js"],
      "css": ["email-scanner.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
